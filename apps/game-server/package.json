{
  "name": "@sgs/game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "host:lan": "node dist/index.js --lan",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sgs/content-schema": "*",
    "@sgs/headless-engine": "*",
    "@sgs/protocol": "*",
    "bonjour-service": "^1.4.3",
    "express": "^5.1.0",
    "sharp": "^0.35.3",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4"
  }
}
